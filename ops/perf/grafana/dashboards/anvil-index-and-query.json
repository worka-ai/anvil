{
  "uid": "anvil-index-and-query",
  "title": "Index And Query",
  "tags": [
    "anvil",
    "index",
    "query"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-2h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Query plan duration",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "greptime"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "greptime"
          },
          "format": "table",
          "rawSql": "SELECT index_kind, authz_pruned, boundary_pruned, COUNT(*) AS samples, AVG(duration_ms) AS avg_ms, MAX(duration_ms) AS max_ms FROM anvil_query_plan_duration_ms GROUP BY index_kind, authz_pruned, boundary_pruned ORDER BY max_ms DESC LIMIT 50",
          "rawQuery": true
        }
      ],
      "options": {}
    },
    {
      "id": 2,
      "type": "table",
      "title": "Boundary pruning ratio",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "greptime"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "greptime"
          },
          "format": "table",
          "rawSql": "SELECT boundary_dimension, writer_family, index_kind, AVG(value) AS avg_ratio, MAX(value) AS max_ratio FROM anvil_boundary_prune_ratio GROUP BY boundary_dimension, writer_family, index_kind ORDER BY avg_ratio DESC LIMIT 50",
          "rawQuery": true
        }
      ],
      "options": {}
    },
    {
      "id": 3,
      "type": "table",
      "title": "Authz candidate pruning ratio",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "greptime"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "greptime"
          },
          "format": "table",
          "rawSql": "SELECT object_namespace, relation, index_kind, AVG(value) AS avg_ratio, MAX(value) AS max_ratio FROM anvil_authz_candidate_prune_ratio GROUP BY object_namespace, relation, index_kind ORDER BY avg_ratio DESC LIMIT 50",
          "rawQuery": true
        }
      ],
      "options": {}
    },
    {
      "id": 4,
      "type": "table",
      "title": "Logical ranges read per query",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "greptime"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "greptime"
          },
          "format": "table",
          "rawSql": "SELECT index_kind, writer_family, SUM(count) AS ranges_read FROM anvil_query_ranges_read_total GROUP BY index_kind, writer_family ORDER BY ranges_read DESC LIMIT 50",
          "rawQuery": true
        }
      ],
      "options": {}
    },
    {
      "id": 5,
      "type": "table",
      "title": "Query trace pruning spans",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "greptime"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "greptime"
          },
          "format": "table",
          "rawSql": "SELECT operation, status, COUNT(*) AS samples, SUM(bytes_in) AS bytes_in, SUM(bytes_out) AS bytes_out, AVG(duration_micros) AS avg_micros FROM anvil_trace_event WHERE operation IN ('query.plan','query.authz_prune','query.boundary_prune') GROUP BY operation, status ORDER BY avg_micros DESC LIMIT 50",
          "rawQuery": true
        }
      ],
      "options": {}
    }
  ]
}
