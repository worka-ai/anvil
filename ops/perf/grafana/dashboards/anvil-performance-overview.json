          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT plane, method, status, COUNT(*) AS samples, AVG(duration_ms) AS avg_ms, MAX(duration_ms) AS max_ms FROM anvil_request_duration_ms GROUP BY plane, method, status ORDER BY max_ms DESC LIMIT 50",
