{
  "uid": "anvil-index-watch-and-gates",
  "title": "Anvil Index, Watch, and Release Gates",
  "tags": [
    "anvil",
    "performance"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-2h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Test/release-gate spans",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "greptime"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "greptime"
          },
          "format": "table",
          "rawSql": "SELECT span, COUNT(*) AS samples, AVG(duration_ms) AS avg_ms, MAX(duration_ms) AS max_ms FROM anvil_test_span GROUP BY span ORDER BY max_ms DESC LIMIT 80",
          "rawQuery": true
        }
      ],
      "options": {},
      "description": "Timing spans emitted by tests and release gates. Useful for checking whether waits are real work or harness delay."
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Performance cases over time",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "greptime"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "greptime"
          },
          "format": "time_series",
          "rawSql": "SELECT greptime_timestamp AS time, `case` AS metric, duration_ms FROM anvil_perf_case ORDER BY greptime_timestamp",
          "rawQuery": true
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Index/query request latency",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "greptime"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "greptime"
          },
          "format": "table",
          "rawSql": "SELECT path, status, COUNT(*) AS requests, AVG(duration_ms) AS avg_ms, MAX(duration_ms) AS max_ms FROM anvil_request WHERE path LIKE '/anvil.IndexService/%' GROUP BY path, status ORDER BY max_ms DESC",
          "rawQuery": true
        }
      ],
      "options": {}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Index/query request timeline",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "greptime"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "greptime"
          },
          "format": "time_series",
          "rawSql": "SELECT greptime_timestamp AS time, CONCAT(path, ' ', status) AS metric, duration_ms FROM anvil_request WHERE path LIKE '/anvil.IndexService/%' ORDER BY greptime_timestamp",
          "rawQuery": true
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Cluster startup and convergence spans",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "greptime"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "greptime"
          },
          "format": "table",
          "rawSql": "SELECT span, COUNT(*) AS samples, AVG(duration_ms) AS avg_ms, MAX(duration_ms) AS max_ms FROM anvil_test_span WHERE span LIKE 'start_and_converge%' GROUP BY span ORDER BY max_ms DESC",
          "rawQuery": true
        }
      ],
      "options": {}
    },
    {
      "id": 6,
      "type": "table",
      "title": "Object write/read/list route timings",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "greptime"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "greptime"
          },
          "format": "table",
          "rawSql": "SELECT path, COUNT(*) AS requests, AVG(duration_ms) AS avg_ms, MAX(duration_ms) AS max_ms FROM anvil_request WHERE path LIKE '/anvil.ObjectService/%' OR path LIKE '/anvil.BucketService/%' GROUP BY path ORDER BY max_ms DESC",
          "rawQuery": true
        }
      ],
      "options": {}
    }
  ]
}
