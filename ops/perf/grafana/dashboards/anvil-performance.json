{
  "uid": "anvil-performance",
  "title": "Anvil Performance",
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request latency by path",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "greptime"},
          "format": "time_series",
          "rawSql": "SELECT ts AS time, CONCAT(path, ' ', status) AS metric, duration_ms FROM anvil_request_mux WHERE $__timeFilter(ts) ORDER BY ts"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Internal spans",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "greptime"},
          "format": "time_series",
          "rawSql": "SELECT ts AS time, span AS metric, duration_ms FROM anvil_internal_span WHERE $__timeFilter(ts) ORDER BY ts"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Performance cases",
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 8},
      "targets": [
        {
          "datasource": {"type": "mysql", "uid": "greptime"},
          "format": "time_series",
          "rawSql": "SELECT ts AS time, case AS metric, duration_ms FROM anvil_perf_case WHERE $__timeFilter(ts) ORDER BY ts"
        }
      ]
    }
  ]
}
